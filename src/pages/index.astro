---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SdkCard from '../components/SdkCard.astro';
import AppCard from '../components/AppCard.astro';
import StackOverflowSummary from '../components/StackOverflowSummary.astro';
import ContactCards from '../components/ContactCards.astro';
import { STACK_OVERFLOW } from '../data/stackoverflow';
import { SDKS } from '../data/sdks';
import type { Sdk } from '../types';
import { FEATURED_APPS } from '../data/apps';
import { APP_STORE_DEVELOPER_URL } from '../data/site';
import { PROFILE } from '../data/profile';
import { readingTime } from '../lib/reading-time';
import { articleSlug } from '../lib/slug';

const published = (await getCollection('articles')).filter(
  (a) => !a.data.draft
);
published.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = published.slice(0, 5).map((a) => ({
  entry: a,
  readingTime: readingTime(a.body ?? ''),
}));
const otherCount = Math.max(0, published.length - featured.length);

// Showcase 5 SDKs in a fixed order; the 6th grid box is a "view all" link.
const SDK_ORDER = [
  'orbitcore-ios',
  'conduit-ios',
  'geo-clustering-ios',
  'localization-engine-ios',
  'event-horizon-ios',
];
const featuredSdks = SDK_ORDER.map((n) => SDKS.find((s) => s.name === n)).filter(
  (s): s is Sdk => Boolean(s)
);
---

<BaseLayout title={PROFILE.name}>
  <Hero />

  <!-- 01 / Stack Overflow -->
  <section class="section" id="stackoverflow" aria-labelledby="so-heading">
    <div class="container">
      <SectionHeading
        number="01"
        title="Stack Overflow"
        id="so-heading"
        description="A snapshot of my Stack Overflow profile — reputation, badges, and reach across the community."
      />
      <div data-reveal>
        <StackOverflowSummary />
      </div>
      <div class="section__cta">
        <a class="link-accent" href={STACK_OVERFLOW.url} target="_blank" rel="noopener noreferrer">
          View full profile on Stack Overflow <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 02 / Latest articles -->
  {
    featured.length > 0 && (
      <section class="section section--alt" aria-labelledby="writing-heading">
        <div class="container">
          <SectionHeading
            number="02"
            title="Latest writing"
            id="writing-heading"
            description="Notes on Swift 6 concurrency, SDK design, and iOS architecture."
          />
          <div class="article-grid">
            {featured.map((a, i) => (
              <ArticleCard
                title={a.entry.data.title}
                description={a.entry.data.description}
                date={a.entry.data.date}
                readingTime={a.readingTime}
                tags={a.entry.data.tags}
                slug={articleSlug(a.entry.id)}
                image={a.entry.data.heroImage}
                index={i}
              />
            ))}
            <a
              class="sdk-all"
              data-reveal
              style={`--d:${(featured.length % 3) * 80}ms`}
              href="/articles"
            >
              <span class="sdk-all__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 5h13M4 10h13M4 15h9" />
                  <path d="M15 13l4 4-4 4" />
                </svg>
              </span>
              <span class="sdk-all__title">View all articles</span>
              <span class="sdk-all__sub">
                {otherCount > 0 ? `${otherCount} more →` : 'Read all →'}
              </span>
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- 03 / SDKs -->
  <section class="section" id="sdks" aria-labelledby="sdks-heading">
    <div class="container">
      <SectionHeading
        number="03"
        title="Swift SDKs"
        id="sdks-heading"
        description="Open-source Swift packages I design and maintain — protocol-first, fully testable, built for Swift 6 strict concurrency."
      />
      <div class="sdk-grid">
        {featuredSdks.map((sdk, i) => <SdkCard sdk={sdk} index={i} />)}
        <a
          class="sdk-all"
          data-reveal
          style={`--d:${(featuredSdks.length % 3) * 80}ms`}
          href="https://github.com/egzonpllana?tab=repositories"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="sdk-all__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49v-1.7c-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.3 9.3 0 0 1 5 0c1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.35 4.79-4.58 5.05.36.32.68.94.68 1.9v2.82c0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2z" />
            </svg>
          </span>
          <span class="sdk-all__title">View all SDKs</span>
          <span class="sdk-all__sub">on GitHub <span aria-hidden="true">↗</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- 04 / Apps -->
  <section class="section section--alt" id="apps" aria-labelledby="apps-heading">
    <div class="container">
      <SectionHeading
        number="04"
        title="App Store apps"
        id="apps-heading"
        description="Consumer apps I have designed, built, and shipped end to end."
      />
      <div class="app-grid">
        {FEATURED_APPS.map((app, i) => <AppCard app={app} index={i} />)}
        <a
          class="sdk-all"
          data-reveal
          style={`--d:${(FEATURED_APPS.length % 3) * 80}ms`}
          href={APP_STORE_DEVELOPER_URL}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="sdk-all__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.05 12.04c-.03-3.16 2.58-4.68 2.7-4.75-1.47-2.15-3.76-2.45-4.57-2.48-1.94-.2-3.79 1.14-4.78 1.14-.98 0-2.5-1.11-4.12-1.08-2.12.03-4.08 1.23-5.17 3.13-2.2 3.82-.56 9.48 1.58 12.58 1.05 1.52 2.3 3.22 3.93 3.16 1.58-.06 2.17-1.02 4.08-1.02 1.9 0 2.44 1.02 4.1.99 1.7-.03 2.77-1.55 3.8-3.08 1.2-1.76 1.69-3.47 1.71-3.56-.04-.02-3.28-1.26-3.31-4.99zM13.9 4.0c.87-1.05 1.45-2.51 1.29-3.97-1.25.05-2.76.83-3.66 1.88-.8.93-1.5 2.42-1.31 3.85 1.39.11 2.81-.71 3.68-1.76z" />
            </svg>
          </span>
          <span class="sdk-all__title">View all apps</span>
          <span class="sdk-all__sub">on the App Store <span aria-hidden="true">↗</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- 05 / Contact -->
  <section class="section" id="contact" aria-labelledby="contact-heading">
    <div class="container">
      <SectionHeading
        number="05"
        title="Get in touch"
        id="contact-heading"
        description="The fastest ways to reach me — email, or anywhere I'm active publicly."
        descFull
      />
      <ContactCards />
    </div>
  </section>
</BaseLayout>

<style>
  .section--alt {
    background: var(--bg-subtle);
    border-block: 1px solid var(--border);
  }
  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--sp-4);
    align-items: stretch;
  }
  .sdk-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: var(--sp-4);
  }
  .sdk-all {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    text-align: center;
    padding: var(--sp-5);
    border: 1px dashed var(--border-strong);
    border-radius: var(--radius);
    background: var(--bg-subtle);
    color: var(--fg-muted);
    min-height: 180px;
    transition: border-color 0.18s var(--ease), color 0.18s var(--ease),
      background 0.18s var(--ease), transform 0.18s var(--ease);
  }
  .sdk-all:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-soft);
    transform: translateY(-3px);
  }
  .sdk-all__icon svg {
    width: 30px;
    height: 30px;
  }
  .sdk-all__title {
    font-weight: 600;
    font-size: var(--fs-md);
    color: var(--fg);
  }
  .sdk-all:hover .sdk-all__title {
    color: var(--accent);
  }
  .sdk-all__sub {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
  }
  .app-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--sp-4);
  }
  .section__cta {
    margin-top: var(--sp-6);
  }
</style>
