---
import { STACK_OVERFLOW as SO } from '../data/stackoverflow';

const W = 240;
const H = 70;
const series = SO.repSeries;
const min = Math.min(...series);
const max = Math.max(...series);
const range = max - min || 1;
const stepX = W / (series.length - 1);

const pts = series.map((v, i) => {
  const x = i * stepX;
  const y = H - ((v - min) / range) * (H - 6) - 3;
  return [x, y] as const;
});
const linePath = pts.map(([x, y], i) => `${i === 0 ? 'M' : 'L'}${x.toFixed(1)} ${y.toFixed(1)}`).join(' ');
const areaPath = `${linePath} L${W} ${H} L0 ${H} Z`;

const fmt = (n: number) => n.toLocaleString('en-US');
const nice = (n: number) => (n >= 1000 ? `${(n / 1000).toFixed(n % 1000 === 0 ? 0 : 1)}k` : `${n}`);
const yTicks = [max, min + range / 2, min].map((v) => Math.round(v / 100) * 100);
---

<div class="so-grid">
  <!-- Reputation -->
  <a class="so-panel" href={SO.url} target="_blank" rel="noopener noreferrer">
    <span class="so-panel__label">Reputation</span>
    <div class="so-rep">
      <div class="so-rep__left">
        <div class="so-rep__num">{fmt(SO.reputation)}</div>
        <span class="so-chip so-chip--green">+{SO.reputationDelta}</span>
      </div>
      <div class="so-chart">
        <div class="so-chart__yaxis">
          {yTicks.map((t) => <span>{nice(t)}</span>)}
        </div>
        <div class="so-chart__plot">
          <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none" aria-hidden="true">
            <defs>
              <linearGradient id="so-fill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="var(--so-green)" stop-opacity="0.28" />
                <stop offset="1" stop-color="var(--so-green)" stop-opacity="0" />
              </linearGradient>
            </defs>
            <line x1="0" y1="3" x2={W} y2="3" class="so-grid-line" />
            <line x1="0" y1={H / 2} x2={W} y2={H / 2} class="so-grid-line" />
            <line x1="0" y1={H - 3} x2={W} y2={H - 3} class="so-grid-line" />
            <path d={areaPath} fill="url(#so-fill)" />
            <path d={linePath} class="so-line" fill="none" />
          </svg>
          <div class="so-chart__xaxis">
            {SO.years.map((y) => <span>{y}</span>)}
          </div>
        </div>
      </div>
    </div>
    <div class="so-rep__foot">
      <div class="so-foot-block">
        <span class="so-mini-label">Top tag</span>
        <span class="so-tag"><b>+{SO.topTag.score}</b> {SO.topTag.name}</span>
      </div>
      <div class="so-foot-block so-foot-block--grow">
        <span class="so-mini-label">Next privilege</span>
        <span class="so-priv">{SO.nextPrivilege.name}</span>
      </div>
      <span class="so-priv-rep">{fmt(SO.nextPrivilege.at)} Rep.</span>
    </div>
  </a>

  <!-- Badges -->
  <a class="so-panel" href={`${SO.url}?tab=badges`} target="_blank" rel="noopener noreferrer">
    <div class="so-panel__head">
      <span class="so-panel__label">Badges</span>
      <span class="so-panel__count">{SO.badgesTotal} total</span>
    </div>
    <div class="so-badges">
      {SO.topBadges.map((b) => (
        <span class={`so-badge so-badge--${b.tier}`}>
          <span class="dot" />
          {b.name}
          {b.count > 1 && <span class="so-badge__x">×{b.count}</span>}
        </span>
      ))}
    </div>
    <div class="so-rep__foot so-rep__foot--badges">
      <div class="so-foot-block so-foot-block--grow">
        <span class="so-mini-label">Next badge</span>
        <span class="so-named-badge"><span class="dot dot--bronze"></span>{SO.nextBadge.name}</span>
      </div>
      <span class="so-priv-rep">{SO.nextBadge.progress}</span>
    </div>
  </a>

  <!-- Impact -->
  <a class="so-panel" href={SO.url} target="_blank" rel="noopener noreferrer">
    <span class="so-panel__label">Impact</span>
    <div class="so-impact">
      <div class="so-stat">
        <span class="so-stat__num">{SO.impact.peopleReached}</span>
        <span class="so-stat__label">people reached</span>
      </div>
      <div class="so-stat">
        <span class="so-stat__num">{SO.impact.postsEdited}</span>
        <span class="so-stat__label">post edited</span>
      </div>
      <div class="so-stat">
        <span class="so-stat__num">{SO.impact.helpfulFlags}</span>
        <span class="so-stat__label">helpful flag</span>
      </div>
      <div class="so-stat">
        <span class="so-stat__num">{fmt(SO.impact.votesCast)}</span>
        <span class="so-stat__label">votes cast</span>
      </div>
    </div>
  </a>
</div>

<style>
  .so-grid {
    --so-green: #3fb950;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: var(--sp-4);
  }
  @media (max-width: 880px) {
    .so-grid {
      grid-template-columns: 1fr;
    }
  }
  .so-panel {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    padding: var(--sp-5);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--fg);
    transition: border-color 0.18s var(--ease), transform 0.18s var(--ease),
      box-shadow 0.18s var(--ease);
  }
  .so-panel:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .so-panel__label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-faint);
  }

  /* Reputation */
  .so-rep {
    display: flex;
    gap: var(--sp-5);
    align-items: flex-start;
  }
  .so-rep__left {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .so-rep__num {
    font-size: var(--fs-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .so-chip {
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: 600;
    padding: 0.15rem 0.55rem;
    border-radius: 6px;
  }
  .so-chip--green {
    color: var(--so-green);
    background: color-mix(in srgb, var(--so-green) 16%, transparent);
    border: 1px solid color-mix(in srgb, var(--so-green) 40%, transparent);
  }
  .so-chart {
    flex: 1;
    display: flex;
    gap: var(--sp-2);
    min-width: 0;
  }
  .so-chart__yaxis {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--fg-faint);
    height: 70px;
    text-align: right;
  }
  .so-chart__plot {
    flex: 1;
    min-width: 0;
  }
  .so-chart__plot svg {
    width: 100%;
    height: 70px;
    display: block;
  }
  .so-grid-line {
    stroke: var(--border);
    stroke-width: 1;
  }
  .so-line {
    stroke: var(--so-green);
    stroke-width: 2;
    stroke-linejoin: round;
    stroke-linecap: round;
    vector-effect: non-scaling-stroke;
  }
  .so-chart__xaxis {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--fg-faint);
    margin-top: 0.25rem;
  }

  .so-rep__foot {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin-top: auto;
    padding-top: var(--sp-3);
    border-top: 1px solid var(--border);
  }
  .so-rep__foot--badges {
    margin-top: auto;
  }
  .so-foot-block {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .so-foot-block--grow {
    flex: 1;
    min-width: 0;
  }
  .so-mini-label {
    font-size: var(--fs-xs);
    color: var(--fg-faint);
  }
  .so-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    padding: 0.15rem 0.5rem;
    border-radius: 6px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    align-self: flex-start;
  }
  .so-tag b {
    color: var(--so-green);
  }
  .so-priv {
    font-size: var(--fs-sm);
    color: var(--fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .so-priv-rep {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--fg-faint);
    white-space: nowrap;
  }

  /* Badges */
  .so-panel__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
  }
  .so-panel__count {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--fg-faint);
  }
  .so-badges {
    display: flex;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .so-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 540;
    font-size: var(--fs-sm);
    padding: 0.3rem 0.65rem;
    border-radius: 8px;
    border: 1px solid var(--border-strong);
    background: var(--bg-subtle);
  }
  .so-badge__x {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--fg-faint);
    font-weight: 500;
  }
  .so-badge .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex: 0 0 auto;
  }
  .so-badge--gold .dot {
    background: #f1b600;
  }
  .so-badge--silver .dot {
    background: #b4b8bc;
  }
  .so-badge--bronze .dot {
    background: #cd7f32;
  }
  .so-named-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--fs-sm);
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    align-self: flex-start;
  }
  .so-named-badge .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--fg-faint);
  }
  .so-named-badge .dot--bronze {
    background: #cd7f32;
  }

  /* Impact */
  .so-impact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4) var(--sp-5);
  }
  .so-stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .so-stat__num {
    font-size: var(--fs-lg);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .so-stat__label {
    font-size: var(--fs-xs);
    color: var(--fg-muted);
  }
</style>
