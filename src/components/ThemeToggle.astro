---
// Toggles the document theme; persists choice in localStorage.
---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="Toggle color theme"
  aria-pressed="false"
  title="Toggle theme"
>
  <svg class="icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" stroke-linecap="round" />
  </svg>
  <svg class="icon icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" stroke-linejoin="round" />
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    transition: background 0.18s var(--ease), color 0.18s var(--ease),
      border-color 0.18s var(--ease);
  }
  .theme-toggle:hover {
    background: var(--surface-hover);
    color: var(--fg);
    border-color: var(--border-strong);
  }
  .icon {
    width: 19px;
    height: 19px;
    grid-area: 1 / 1;
  }
  /* Show sun in dark mode (to switch to light), moon in light mode. */
  .icon-sun {
    display: none;
  }
  :global(:root[data-theme='dark']) .icon-sun {
    display: block;
  }
  :global(:root[data-theme='dark']) .icon-moon {
    display: none;
  }
</style>

<script is:inline>
  (() => {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const sync = () => {
      const dark = document.documentElement.dataset.theme === 'dark';
      btn.setAttribute('aria-pressed', String(dark));
    };
    btn.addEventListener('click', () => {
      const next =
        document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch (e) {}
      sync();
    });
    sync();
  })();
</script>
