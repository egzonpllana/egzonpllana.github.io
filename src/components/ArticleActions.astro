---
interface Props {
  repoUrl?: string;
  showShare?: boolean;
}
const { repoUrl, showShare = false } = Astro.props;
---

<div class="aa">
  {
    repoUrl && (
      <a class="aa-repo" href={repoUrl} target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49v-1.7c-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.3 9.3 0 0 1 5 0c1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.35 4.79-4.58 5.05.36.32.68.94.68 1.9v2.82c0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2z" />
        </svg>
        View the SDK on GitHub
        <span class="aa-ext" aria-hidden="true">↗</span>
      </a>
    )
  }

  {showShare && (
  <div class="aa-buttons">
    <button class="aa-btn" type="button" data-copy aria-label="Copy link to this article">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1" />
        <path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1" />
      </svg>
      <span class="aa-label">Copy link</span>
    </button>
    <button class="aa-btn" type="button" data-share aria-label="Share this article">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="18" cy="5" r="3" />
        <circle cx="6" cy="12" r="3" />
        <circle cx="18" cy="19" r="3" />
        <path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4" />
      </svg>
      <span class="aa-label">Share</span>
    </button>
  </div>
  )}
</div>

<style>
  .aa {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-3);
  }
  .aa-repo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.9rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-strong);
    background: var(--surface);
    font-size: var(--fs-sm);
    font-weight: 540;
    color: var(--fg);
    transition: border-color 0.18s var(--ease), background 0.18s var(--ease),
      color 0.18s var(--ease);
  }
  .aa-repo:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-soft);
  }
  .aa-repo svg {
    width: 17px;
    height: 17px;
  }
  .aa-ext {
    color: var(--fg-faint);
  }
  .aa-buttons {
    display: flex;
    gap: var(--sp-2);
    margin-left: auto;
  }
  .aa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.8rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--fg-muted);
    font-size: var(--fs-sm);
    transition: border-color 0.18s var(--ease), color 0.18s var(--ease),
      background 0.18s var(--ease);
  }
  .aa-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-soft);
  }
  .aa-btn svg {
    width: 16px;
    height: 16px;
  }
  @media (max-width: 520px) {
    .aa-buttons {
      margin-left: 0;
    }
  }
</style>
