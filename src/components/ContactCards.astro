---
import { SITE, APP_STORE_DEVELOPER_URL } from '../data/site';
import { STACK_OVERFLOW } from '../data/stackoverflow';

type IconKey =
  | 'email'
  | 'linkedin'
  | 'github'
  | 'medium'
  | 'stackoverflow'
  | 'appstore';

interface Contact {
  label: string;
  value: string;
  href: string;
  icon: IconKey;
  external?: boolean;
}

const CONTACTS: Contact[] = [
  { label: 'Email', value: SITE.email, href: `mailto:${SITE.email}`, icon: 'email' },
  { label: 'LinkedIn', value: 'in/egzon-pllana', href: 'https://linkedin.com/in/egzon-pllana', icon: 'linkedin', external: true },
  { label: 'GitHub', value: '@egzonpllana', href: 'https://github.com/egzonpllana', icon: 'github', external: true },
  { label: 'Medium', value: '@egzonpllana', href: 'https://medium.com/@egzonpllana', icon: 'medium', external: true },
  { label: 'Stack Overflow', value: 'egzon-p', href: STACK_OVERFLOW.url, icon: 'stackoverflow', external: true },
  { label: 'App Store', value: 'Developer page', href: APP_STORE_DEVELOPER_URL, icon: 'appstore', external: true },
];

const ICONS: Record<IconKey, string> = {
  email:
