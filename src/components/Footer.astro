---
import { NAV, SITE } from '../data/site';
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="footer__name">{SITE.name}</span>
      <p class="footer__tag">Senior iOS Engineer · SDK &amp; Mobile Architect</p>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="/rss.xml">RSS</a>
    </nav>

    <SocialLinks size={18} />
  </div>

  <div class="container footer__base">
    <span>© {year} {SITE.name}. All rights reserved.</span>
    <span class="footer__built">Built with Astro</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg-subtle);
    padding-block: var(--sp-7) var(--sp-5);
    margin-top: var(--sp-9);
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-5);
  }
  .footer__name {
    font-weight: 640;
    font-size: var(--fs-md);
  }
  .footer__tag {
    color: var(--fg-muted);
    font-size: var(--fs-sm);
    margin-top: var(--sp-1);
  }
  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    font-size: var(--fs-sm);
  }
  .footer__nav a {
    color: var(--fg-muted);
  }
  .footer__nav a:hover {
    color: var(--accent);
  }
  .footer__base {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
    padding-top: var(--sp-5);
    border-top: 1px solid var(--border);
    font-size: var(--fs-xs);
    color: var(--fg-faint);
    font-family: var(--font-mono);
  }
</style>
