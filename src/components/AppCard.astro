---
import type { App } from '../types';

interface Props {
  app: App;
  index?: number;
}

const { app, index = 0 } = Astro.props;
---

<article class="app" data-reveal style={`--d:${(index % 3) * 80}ms`}>
  <a
    class="app__link"
    href={app.appStoreUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`${app.name} on the App Store`}></a>

  <img
    class="app__icon"
    src={app.iconUrl}
    alt={`${app.name} app icon`}
    width="72"
    height="72"
    loading="lazy"
    decoding="async"
  />

  <div class="app__body">
    <span class="app__category">{app.category}</span>
    <h3 class="app__name">{app.name}</h3>
    <p class="app__blurb">{app.blurb}</p>
    <span class="app__cta link-accent">
      App Store <span aria-hidden="true">↗</span>
    </span>
  </div>
</article>

<style>
  .app {
    position: relative;
    display: flex;
    gap: var(--sp-4);
    padding: var(--sp-5);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    transition: border-color 0.18s var(--ease), transform 0.18s var(--ease),
      box-shadow 0.18s var(--ease);
  }
  .app:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .app__link {
    position: absolute;
    inset: 0;
    border-radius: var(--radius);
  }
  .app__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .app__icon {
    width: 64px;
    height: 64px;
    border-radius: 15px;
    border: 1px solid var(--border);
    flex-shrink: 0;
    object-fit: cover;
  }
  .app__body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }
  .app__category {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-faint);
  }
  .app__name {
    font-size: var(--fs-md);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .app__blurb {
    font-size: var(--fs-sm);
    color: var(--fg-muted);
    line-height: 1.5;
  }
  .app__cta {
    margin-top: var(--sp-2);
    font-size: var(--fs-sm);
  }
</style>
