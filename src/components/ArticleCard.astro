---
import { formatDate, isoDate } from '../lib/format-date';

interface Props {
  title: string;
  description: string;
  date: Date;
  readingTime: number;
  tags: string[];
  slug: string;
  featured?: boolean;
  image?: string;
  index?: number;
}

const {
  title,
  description,
  date,
  readingTime,
  tags,
  slug,
  featured = false,
  image,
  index = 0,
} = Astro.props;
const href = `/articles/${slug}`;
---

<article
  class:list={['acard', { 'acard--featured': featured, 'acard--media': !!image }]}
  data-reveal
  style={`--d:${(index % 3) * 80}ms`}
>
  <a class="acard__link" href={href} aria-label={title}></a>

  {
    image && (
      <div class="acard__media">
        <img src={image} alt={`${title} cover`} loading="lazy" decoding="async" />
      </div>
    )
  }

  <div class="acard__body">
  <div class="acard__meta">
    {featured && <span class="acard__flag">Latest</span>}
    <time datetime={isoDate(date)}>{formatDate(date)}</time>
    <span class="acard__dot" aria-hidden="true">·</span>
    <span>{readingTime} min read</span>
  </div>

  <h3 class="acard__title">{title}</h3>
  <p class="acard__desc">{description}</p>

  <div class="acard__footer">
    {
      tags.length > 0 && (
        <ul class="acard__tags">
          {tags.slice(0, 3).map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )
    }
    <span class="acard__read link-accent">
      Read article <span aria-hidden="true">→</span>
    </span>
  </div>
  </div>
</article>

<style>
  .acard {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    transition: border-color 0.18s var(--ease), transform 0.18s var(--ease),
      box-shadow 0.18s var(--ease);
  }
  .acard:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .acard__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: var(--bg-subtle);
  }
  .acard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }
  .acard:hover .acard__media img {
    transform: scale(1.04);
  }
  .acard--featured.acard--media .acard__media {
    aspect-ratio: 21 / 9;
  }
  .acard__body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-5);
    flex: 1;
  }
  .acard__link {
    position: absolute;
    inset: 0;
    border-radius: var(--radius);
    z-index: 1;
  }
  .acard__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .acard--featured {
    border-left: 3px solid var(--accent);
  }
  .acard__meta {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--fg-faint);
  }
  .acard__flag {
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 999px;
    padding: 0.05rem 0.5rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .acard__title {
    font-size: var(--fs-lg);
  }
  .acard--featured .acard__title {
    font-size: var(--fs-xl);
  }
  .acard__desc {
    color: var(--fg-muted);
    font-size: var(--fs-sm);
  }
  .acard__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    margin-top: auto;
    padding-top: var(--sp-2);
  }
  .acard__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    list-style: none;
    padding: 0;
  }
  .acard__read {
    position: relative;
    z-index: 2;
    font-size: var(--fs-sm);
    white-space: nowrap;
  }
</style>
